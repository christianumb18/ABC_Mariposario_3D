  m_Name: 
  m_EditorClassIdentifier: 
  nombre: Siproeta Stelenes Biplagiata
  familia: Nymphalidae
  genero: Siproeta
  especie: Siproeta stelenes
  subespecie: Siproeta stelenes biplagiata
  habitat: "Bosques tropicales y subtropicales desde el sur de Estados Unidos hasta
    Am\xE9rica del Sur."
  planta_hospedadora: Blechum spp. y Ruellia spp. (familia Acanthaceae)
  descripcion: "Hierbas y arbustos que crecen en \xE1reas abiertas y bordes de bosques,
    utilizadas por las larvas para su desarrollo."
  caracteristicas: "Conocida como la mariposa chocolate, presenta alas de color marr\xF3n
    oscuro con una banda anaranjada distintiva que atraviesa las alas anteriores.
    Su envergadura es de aproximadamente 7 a 8 cent\xEDmetros."
  quizData: {fileID: 0}
