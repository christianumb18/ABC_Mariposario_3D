  m_Script: {fileID: 11500000, guid: fad7cb8db56686a44a9dee24a5b7f7c6, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  nombre: Mechantis Lysimnia
  familia: Nymphalidae
  genero: Mechanitis
  especie: M. lysimnia
  subespecie: Varias, como M. lysimnia lysimnia y M. lysimnia fabricii
  habitat: "Bosques tropicales y subtropicales de Am\xE9rica Central y del Sur"
  planta_hospedadora: Solanum (familia Solanaceae)
  descripcion: "Mariposa de tama\xF1o mediano con alas anaranjadas con negro y detalles
    blancos. Con patrones similares a los de las mariposas del grupo \xABtigre\xBB."
  caracteristicas: "Envergadura: Entre 5 y 7 cm. Mimetismo: Es t\xF3xica y comparte
    su apariencia con otras especies venenosas para reforzar la se\xF1al de advertencia.
    Vuelo lento: Suele volar pausadamente, lo que ayuda a exhibir sus colores de
    advertencia. Actividad: Es diurna y suele encontrarse en grupos cerca de fuentes
    de alimento o en \xE1reas soleadas dentro del bosque."
  quizData: {fileID: 0}
